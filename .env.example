# Email Verifier Configuration
# Copy this file to .env and customize

# Verifier email used for SMTP MAIL FROM (required for SMTP verification)
VERIFIER_EMAIL=
VERIFIER_DOMAIN=

# SMTP Settings
ENABLE_SMTP_CHECK=false
SMTP_PORT=25
SMTP_CONNECTION_TIMEOUT=5
SMTP_RESPONSE_TIMEOUT=5
SMTP_MAX_ATTEMPTS=2

# Processing Settings
MAX_WORKERS=10
BATCH_SIZE=100

# DNS Settings
DNS_TIMEOUT=5
DNS_CACHE_TTL=3600

# Cache Settings
SMTP_CACHE_TTL=1800
CATCH_ALL_CACHE_TTL=86400

# Custom DNS Server (leave empty for system default)
CUSTOM_DNS_SERVER=

# Logging
LOG_LEVEL=INFO
