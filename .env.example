# Email Verifier Configuration
# Copy this file to .env and customize

# ── Real recipient MX probing ──────────────────────────────────────────
ENABLE_SMTP_CHECK=false
SMTP_VERIFICATION_MODE=disabled
VERIFIER_EMAIL=verifier@company-owned-domain.com
VERIFIER_DOMAIN=company-owned-domain.com
SMTP_PORT=25
SMTP_CONNECTION_TIMEOUT=5
SMTP_RESPONSE_TIMEOUT=5
SMTP_MAX_ATTEMPTS=2
SMTP_MAX_WORKERS=3
SMTP_DOMAIN_RATE_LIMIT=2

# ── Local SMTP testing (Mailpit / test server) ─────────────────────────
SMTP_TEST_MODE=false
TEST_SMTP_HOST=localhost
TEST_SMTP_PORT=1025
TEST_SMTP_USE_TLS=false
TEST_SMTP_USERNAME=
TEST_SMTP_PASSWORD=
MAILPIT_WEB_URL=http://localhost:8025

# ── Processing Settings ────────────────────────────────────────────────
MAX_WORKERS=10
BATCH_SIZE=100

# ── DNS Settings ───────────────────────────────────────────────────────
DNS_TIMEOUT=5
DNS_CACHE_TTL=3600

# ── Cache Settings ─────────────────────────────────────────────────────
SMTP_CACHE_TTL=1800
CATCH_ALL_CACHE_TTL=86400

# ── Custom DNS Server (leave empty for system default) ─────────────────
CUSTOM_DNS_SERVER=

# ── Logging ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Notification SMTP (optional, disabled by default) ─────────────────
# For administrator test notifications only. Never for bulk email.
NOTIFICATION_SMTP_ENABLED=false
NOTIFICATION_SMTP_HOST=
NOTIFICATION_SMTP_PORT=587
NOTIFICATION_SMTP_USERNAME=
NOTIFICATION_SMTP_PASSWORD=
NOTIFICATION_SMTP_USE_TLS=true
NOTIFICATION_FROM_EMAIL=
NOTIFICATION_TO_EMAIL=
